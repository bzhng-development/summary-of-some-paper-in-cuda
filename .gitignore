# Built database lives in local_data/ (100MB+ — exceeds github per-file limit).
# Rebuild via `uv run python sync_db.py` from the committed jsonls + external_papers.db.
# local_data/ also holds scratch snapshots (papers_unified.db, papers_stash3.db, backups).
local_data/

# Legacy top-level paths (kept so older checkouts don't accidentally stage them)
papers.db
papers.db-wal
papers.db-shm

# Local mintlify leftovers
mintlify-ref/

# Per-run build artifacts from daily_papers/hf_daily_papers.py — rebuilt on every run.
# all_scored.json stays tracked (it's the source of truth for scores); relevant.md is a cache.
daily_papers/papers_out/relevant.md
daily_papers/papers_out/by_score/
__pycache__/

